# =============================================================================
# SylviArtes — Environment Secrets (EXAMPLE)
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.
# =============================================================================

# --- Database ---
DB_HOST=localhost
DB_NAME=sylviartes
DB_USER=root
DB_PASS=

# --- Stripe ---
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Run: stripe listen --forward-to localhost:8080/public/stripe_webhook.php
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=eur
SITE_BASE_URL=http://localhost:8080

# --- Resend Email ---
# Create account at https://resend.com, then API Keys → Create API Key
RESEND_API_KEY=your_resend_api_key_here
# Use onboarding@resend.dev for testing, or your verified domain sender
RESEND_FROM=SylviArtes <onboarding@resend.dev>

# --- SMTP (optional fallback, leave blank to skip) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sylviartes.pt
SMTP_FROM_NAME=SylviArtes
